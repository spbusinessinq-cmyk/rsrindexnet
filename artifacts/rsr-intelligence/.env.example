# ── INDEX Data Network — Environment Configuration ────────────────────────────
# Copy this file to .env and fill in the values for your deployment.
# All VITE_* variables are embedded at build time — do NOT store secrets here
# beyond the operator key (which is already non-secret by design — it is a
# passphrase, not an API key).
#
# For Portainer / Docker Compose deployment:
#   1. Set VITE_SOURCE_BASE_URL to the API server's internal address
#      (e.g., http://api-server:4000 if running as a named Docker service)
#   2. Set VITE_OPERATOR_KEY to a strong passphrase for /operator access
#   3. Set internal tool URLs if Grafana, Flowise, etc. are deployed
#   4. Leave VITE_POLL_INTERVAL_MS at default (60000) unless you need faster polls
#
# Same-origin / nginx reverse proxy deployment:
#   Leave VITE_SOURCE_BASE_URL empty — the frontend will use /api/* relative paths,
#   which your reverse proxy should route to the API server container.
# ──────────────────────────────────────────────────────────────────────────────

# ── Operator Authentication ────────────────────────────────────────────────────
# Passphrase required for /operator console access.
# If unset, the login page shows a "locked" state and access is denied.
# Not a secret in the cryptographic sense — it is a shared provisioning passphrase.
VITE_OPERATOR_KEY=

# ── Data Source API Server ─────────────────────────────────────────────────────
# Base URL for the INDEX API server (feed proxy + status endpoints).
# Examples:
#   Docker Compose internal: http://api-server:4000
#   External proxy:          https://api.yourdomain.com
#   Replit dev (override):   https://your-replit-dev-domain/api-server
#
# Leave EMPTY to use same-origin routing (/api/* relative paths).
# Recommended for nginx/Traefik setups where /api/* is proxied to the API container.
VITE_SOURCE_BASE_URL=

# ── Feed Polling Interval ──────────────────────────────────────────────────────
# How often (in milliseconds) the frontend polls each feed source.
# Default: 60000 (60 seconds). Minimum recommended in production: 30000.
# Lower values increase API server load — adjust based on your infrastructure.
VITE_POLL_INTERVAL_MS=60000

# ── Internal Operator Tool URLs ────────────────────────────────────────────────
# Only shown in the /operator console — not visible on public pages.
# Leave empty if the tool is not deployed in your environment.
# The operator UI gracefully shows "URL not configured" for any empty entry.

# Grafana — monitoring dashboards and alerting
VITE_GRAFANA_URL=

# Flowise — AI pipeline visual builder
VITE_FLOWISE_URL=

# Open WebUI — local LLM inference environment
VITE_WEBUI_URL=

# Portainer — Docker container management
VITE_PORTAINER_URL=

# ── Development Only ───────────────────────────────────────────────────────────
# NEVER set this in any non-development environment.
# When true (and running in Vite dev mode), bypasses operator passphrase check.
# Silently ignored in production builds.
VITE_DEV_AUTH_BYPASS=false
