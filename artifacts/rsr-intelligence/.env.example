# ── INDEX Data Network — Environment Configuration ──────────────────────────
# Copy this file to .env and configure for your deployment.
# In Portainer, set these as environment variables in the stack/service config.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Operator Authentication ──────────────────────────────────────────────────
# Required for /operator access.
# Set a strong passphrase. Leave empty to lock operator access entirely.
VITE_OPERATOR_KEY=

# ── Source Feed Base URL ─────────────────────────────────────────────────────
# Base URL of your internal data feed API or proxy.
# All source endpoints are constructed as: {BASE}/feeds/{name}
# Example: http://192.168.12.228:4000
# Leave empty to keep all sources "unbound" (structure active, no live data).
VITE_SOURCE_BASE_URL=

# ── Feed Polling Interval ────────────────────────────────────────────────────
# How often to poll connected sources, in milliseconds.
# Default: 30000 (30 seconds)
VITE_POLL_INTERVAL_MS=30000

# ── Internal Operational Tool URLs (Operator Layer) ──────────────────────────
# These links appear in the operator console.
# Only accessible to authenticated operators.
# VITE_GRAFANA_URL=http://192.168.12.228:3000
# VITE_FLOWISE_URL=http://192.168.12.228:3025
# VITE_WEBUI_URL=http://192.168.12.228:3001
# VITE_PORTAINER_URL=http://192.168.12.228:9000

# ── Development Only ─────────────────────────────────────────────────────────
# Bypass auth gate during local development.
# NEVER set to true in production or Portainer deployment.
# VITE_DEV_AUTH_BYPASS=false
